<Window x:Class="EasySaveWPF.Views.AddJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nouveau Travail" Height="380" Width="450" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Top">

            <TextBlock x:Name="LblName" Text="Nom de la sauvegarde :" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtName" Margin="0,0,0,15" Padding="5"/>

            <TextBlock x:Name="LblSource" Text="Dossier Source :" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtSource" Margin="0,0,0,15" Padding="5"/>

            <TextBlock x:Name="LblTarget" Text="Dossier Cible :" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtTarget" Margin="0,0,0,15" Padding="5"/>

            <TextBlock x:Name="LblType" Text="Type :" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbType" Margin="0,0,0,15" Padding="5">
                <ComboBoxItem Content="Complete" IsSelected="True"/>
                <ComboBoxItem Content="Differential"/>
            </ComboBox>

        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnCancel" Content="Annuler" Width="80" Padding="5" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="Sauvegarder" Width="100" Padding="5" Background="#27AE60" Foreground="White" Click="BtnSave_Click"/>
        </StackPanel>

    </Grid>
</Window>