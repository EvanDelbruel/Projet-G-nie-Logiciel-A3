<Window x:Class="EasySaveWPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres" Height="600" Width="550" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
            <StackPanel>
                <TextBlock x:Name="LblLogFormat" Text="Format des logs (JSON ou XML) :" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbLogFormat" Margin="0,0,0,15" Padding="5">
                    <ComboBoxItem Content="JSON"/>
                    <ComboBoxItem Content="XML"/>
                </ComboBox>

                <TextBlock x:Name="LblBusinessSoftware" Text="Logiciel métier bloquant (ex: notepad) :" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtBusinessSoftware" Margin="0,0,0,15" Padding="5"/>

                <TextBlock x:Name="LblCryptoExtensions" Text="Extensions à crypter (séparées par une virgule, ex: .txt,.pdf) :" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtCryptoExtensions" Margin="0,0,0,15" Padding="5"/>

                <TextBlock x:Name="LblPriorityExtensions" Text="Extensions prioritaires (séparées par une virgule, ex: .txt,.json) :" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtPriorityExtensions" Margin="0,0,0,15" Padding="5"/>

                <TextBlock x:Name="LblMaxFileSize" Text="Taille max pour transfert simultané en Ko (ex: 50) :" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtMaxFileSize" Margin="0,0,0,15" Padding="5"/>

                <TextBlock x:Name="LblLogDestination" Text="Destination des logs :" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbLogDestination" Margin="0,0,0,15" Padding="5">
                    <ComboBoxItem Content="Local"/>
                    <ComboBoxItem Content="Docker"/>
                    <ComboBoxItem Content="Both"/>
                </ComboBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnCancel" Content="Annuler" Width="100" Padding="5" Margin="0,0,10,0" Click="BtnCancel_Click" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="BtnSave" Content="Sauvegarder" Width="100" Padding="5" Click="BtnSave_Click" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>