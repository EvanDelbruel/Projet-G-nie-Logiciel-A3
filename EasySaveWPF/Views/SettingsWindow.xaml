<Window x:Class="EasySaveWPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres / Settings" Height="380" Width="450" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="LblLogFormat" Text="Format des Logs (JSON ou XML) :" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbLogFormat" Margin="0,0,0,15" Padding="5">
                <ComboBoxItem Content="JSON"/>
                <ComboBoxItem Content="XML"/>
            </ComboBox>

            <TextBlock x:Name="LblBusinessSoftware" Text="Logiciel métier bloquant (ex: notepad, CalculatorApp) :" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtBusinessSoftware" Margin="0,0,0,15" Padding="5"/>

            <TextBlock x:Name="LblCryptoExtensions" Text="Extensions à crypter (séparées par une virgule, ex: .txt,.pdf) :" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtCryptoExtensions" Margin="0,0,0,15" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancel" Content="Annuler" Width="80" Padding="5" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="Enregistrer" Width="100" Padding="5" Background="#2980B9" Foreground="White" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>