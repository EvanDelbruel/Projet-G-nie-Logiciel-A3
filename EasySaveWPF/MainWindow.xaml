<Window x:Class="EasySaveWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasySaveWPF.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="500" Width="900" WindowStartupLocation="CenterScreen"
        Icon="/Resources/app_icon.ico">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Resources/logo.png" Height="30" Width="30" Margin="0,0,15,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{Binding WindowTitle}" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding SettingsButtonText}" Command="{Binding SettingsCommand}" 
                            Margin="0,0,15,0" Padding="10,5" Background="#34495E" Foreground="White" 
                            BorderThickness="0" Cursor="Hand"/>

                    <ComboBox ItemsSource="{Binding AvailableLanguages}" 
                              SelectedItem="{Binding SelectedLanguage}" 
                              Width="120" VerticalAlignment="Center" 
                              Padding="5" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="JobsGrid" Grid.Row="1" ItemsSource="{Binding Jobs}" SelectedItem="{Binding SelectedJob}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                  Background="White" RowHeight="40" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DDDDDD"
                  BorderThickness="1" BorderBrush="#CCCCCC">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Name}" Width="*">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding DataContext.HeaderName, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding SourceDirectory}" Width="2*">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding DataContext.HeaderSource, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding TargetDirectory}" Width="2*">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding DataContext.HeaderTarget, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding Type}" Width="120">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding DataContext.HeaderType, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Progression" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="5">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State}" Value="Inactive">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding State}" Value="Stopped">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progression}" Height="20" Foreground="#2ECC71" Background="#EEEEEE"/>
                                <TextBlock Text="{Binding Progression, StringFormat={}{0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="Black"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="120">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="{Binding DataContext.HeaderActions, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="⏸" 
                                        Command="{Binding DataContext.PauseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Width="25" Height="25" Margin="2" Cursor="Hand" Background="#F1C40F" Foreground="Black" BorderThickness="0"
                                        ToolTip="Pause">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding State}" Value="Active">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="▶" 
                                        Command="{Binding DataContext.ResumeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Width="25" Height="25" Margin="2" Cursor="Hand" Background="#2ECC71" Foreground="White" BorderThickness="0"
                                        ToolTip="Play / Resume">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding State}" Value="Active">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="⏹" 
                                        Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Width="25" Height="25" Margin="2" Cursor="Hand" Background="#E74C3C" Foreground="White" BorderThickness="0"
                                        ToolTip="Stop">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding State}" Value="Active">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding State}" Value="Paused">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="White" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <Button Content="{Binding AddButtonText}" Command="{Binding AddCommand}" 
                        Margin="0,0,10,0" Padding="15,10" Background="#27AE60" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>

                <Button Content="{Binding RunButtonText}" Command="{Binding RunCommand}" 
                        CommandParameter="{Binding ElementName=JobsGrid, Path=SelectedItems}"
                        Padding="15,10" Background="#2980B9" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>